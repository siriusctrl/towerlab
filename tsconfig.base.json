{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@towerlab/core": ["packages/core/src/index.ts"],
      "@towerlab/content": ["packages/content/src/index.ts"],
      "@towerlab/cli": ["packages/cli/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
